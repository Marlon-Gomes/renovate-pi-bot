# GitHub Personal Access Token (from the dedicated bot account)
RENOVATE_TOKEN=ghp_your_bot_token_here

# Filter for repositories (e.g., 'your-username/*'; use your own account, not the bot's)
RENOVATE_AUTODISCOVER_FILTER='username/*'

# The Git Author string (e.g., 'Bot Name <email@example.com>')
RENOVATE_GIT_AUTHOR='Renovate Pi Bot <name+renovate@gmail.com>'

# Your local timezone (e.g., 'Europe/London')
RENOVATE_TIMEZONE='UTC'

# Host User and Group IDs (run 'id' to find yours)
RENOVATE_UID=1000
RENOVATE_GID=1000
